{
  "manifest_version": 3,
  "name": "Ad Redirect Bypass",
  "description": "Follows the redirect chain (302 Location headers) to extract the final destination URL and navigates there immediately.",
  "version": "2.0",
  "permissions": [
    "webRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Ad Bypass",
    "default_popup": "popup.html"
  }
}
